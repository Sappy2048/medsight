# Docker ignore file for MedSight
# Prevents bloating the Docker image with local dev files and data

# Python cache and virtual environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Environment and secrets
.env
.env.local
.env.*.local
.env.production
.env.development
*.key
*.pem
secrets/

# Local data storage (Qdrant, cache files)
data/qdrant_storage/
data/fastembed_cache/
*.db
*.sqlite3

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# Documentation
*.md
!README.md
docs/

# Docker files (don't include in build context)
Dockerfile
.dockerignore
docker-compose.yml

# Render blueprint (not needed in image)
render.yaml

# Large binary files
*.pdf
*.zip
*.tar.gz
*.tar
*.rar

# Logs
*.log
logs/